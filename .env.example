# Copy to .env and fill in. Do not commit .env.

# ---------- Digest email ----------
RESEND_API_KEY=
EMAIL_TO=

# ---------- LLM ----------
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# ---------- Feedback: one-click links (email + web) -> Worker -> D1 ----------
# Public URL of your deployed Worker (no trailing slash).
FEEDBACK_ENDPOINT_BASE_URL=https://paperfeeder-feedback.your-subdomain.workers.dev
# Same value as Worker secret FEEDBACK_LINK_SIGNING_SECRET (wrangler secret put).
FEEDBACK_LINK_SIGNING_SECRET=
# Optional: stored on feedback events as reviewer
FEEDBACK_REVIEWER=
# Set to false to hide the “Open Feedback Web Viewer” banner in email (👍/👎 links unchanged). D1 /run still works.
# FEEDBACK_WEB_VIEWER_LINK_IN_EMAIL=false
# Feedback JSON attachments: all | manifest | none (default all). “manifest” = only run_feedback_manifest_*.json.
# FEEDBACK_EMAIL_ATTACHMENTS=manifest

# ---------- Cloudflare API (Python publishes report HTML to D1; apply_feedback reads D1) ----------
CLOUDFLARE_ACCOUNT_ID=
# Token needs D1 read/write on this account (e.g. "Edit Cloudflare Workers" + D1).
CLOUDFLARE_API_TOKEN=
# Same database as Worker binding (Dashboard -> D1 -> database id).
D1_DATABASE_ID=

# ---------- Semantic Scholar (strongly recommended for 👍/👎 links) ----------
# Without a key, resolver rate-limits; many papers may miss semantic_paper_id -> no action_links.
SEMANTIC_SCHOLAR_API_KEY=
